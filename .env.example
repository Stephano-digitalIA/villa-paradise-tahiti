# ============================================================================
# Villa Paradise Tahiti — Environment variables template
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# Reference: docs/06-technique-stack.md § 4 & § 6
# ============================================================================

# ----------------------------------------------------------------------------
# Site
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://villaparadisetahiti.com

# ----------------------------------------------------------------------------
# Stripe — primary payment processor (USD)
# ----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----------------------------------------------------------------------------
# PayPal — alternative payment processor
# ----------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# 'sandbox' for the developer dashboard, 'live' for production credentials.
PAYPAL_MODE=sandbox
# Webhook id from PayPal Developer dashboard (Apps & Credentials → Webhooks).
# Required for /api/paypal/webhook to verify event signatures.
PAYPAL_WEBHOOK_ID=

# ----------------------------------------------------------------------------
# Sanity — headless CMS
# ----------------------------------------------------------------------------
# Leave the projectId as "mock" until you run `npx sanity init`. While set
# to "mock" (or left empty), the site reads from lib/sanity/mock-data.ts
# and the /studio route shows an onboarding card instead of the Studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=mock
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2024-01-01
# Optional — needed only for drafts / previews. Public reads work without it.
SANITY_API_READ_TOKEN=

# ----------------------------------------------------------------------------
# Resend — transactional emails
# ----------------------------------------------------------------------------
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@villaparadisetahiti.com
EMAIL_OWNER=contact@villaparadisetahiti.com

# ----------------------------------------------------------------------------
# Analytics
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_HOTJAR_ID=
# Optional — only required for the server-side /api/track endpoint, which
# forwards events via the GA4 Measurement Protocol (used by Stripe/PayPal
# webhooks that can't call window.gtag). Create in GA4 Admin → Data Streams
# → Measurement Protocol API secrets.
GA_API_SECRET=

# ----------------------------------------------------------------------------
# Calendar — iCal sync (Airbnb + Booking.com + VRBO)
# ----------------------------------------------------------------------------
# Generate each URL from the host's own dashboard:
#  - Airbnb       → Today → Calendar → ⚙ → Sync calendars → Export calendar
#  - Booking.com  → Extranet → Rates & Availability → Sync calendars → Export
#  - VRBO         → Calendar → Settings → Reservation manager → iCal export
# Treat these as secrets — anyone with the URL can read your bookings.
AIRBNB_ICAL_URL=https://www.airbnb.com/calendar/ical/xxx.ics
BOOKING_ICAL_URL=
VRBO_ICAL_URL=

# ----------------------------------------------------------------------------
# Cron — protected scheduled jobs
# ----------------------------------------------------------------------------
# Used by:
#   - /api/ical/sync  (the only protected endpoint right now)
#   - netlify/functions/ical-sync.mts  (Netlify Scheduled Function, runs hourly,
#     calls /api/ical/sync with `Authorization: Bearer ${CRON_SECRET}`)
# Generate a strong random value with:
#   openssl rand -hex 32           (or)   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
CRON_SECRET=your-long-random-secret-here
